rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // - uid: string (required)
    // - email: string (required)
    // - role: string (required, enum: ['admin', 'user'])
    //
    // Collection: books
    // - title: string (required)
    // - author: string (required)
    // - pdfUrl: string (required)
    //
    // Collection: categories
    // - name: string (required)
    //
    // Collection: reading_progress
    // - userId: string (required)
    // - bookId: string (required)
    //
    // Collection: favorites
    // - userId: string (required)
    // - bookId: string (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "muhammadmohiuddin151@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.role in ['admin', 'user'] &&
             data.uid is string && data.email is string;
    }

    function isValidBook(data) {
      return data.keys().hasAll(['title', 'author', 'pdfUrl']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.pdfUrl is string && data.pdfUrl.size() > 0 &&
             (!('totalPages' in data) || data.totalPages is number) &&
             (!('estimatedReadingTime' in data) || data.estimatedReadingTime is string) &&
             (!('averageRating' in data) || data.averageRating is number) &&
             (!('totalRatings' in data) || data.totalRatings is number);
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'bookId']) &&
             data.userId is string && data.bookId is string;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['userId', 'bookId', 'lastPage', 'progressPercent']) &&
             data.userId is string && data.bookId is string &&
             data.lastPage is number && data.progressPercent is number;
    }

    function isValidRating(data) {
      return data.keys().hasAll(['userId', 'bookId', 'rating']) &&
             data.userId is string && data.bookId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && (
                      isAdmin() || 
                      (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role)
                    );
    }

    match /books/{bookId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBook(request.resource.data);
      allow delete: if isAdmin();
      allow update: if (isAdmin() && isValidBook(request.resource.data)) || 
                      (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalReads', 'averageRating', 'totalRatings']));
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reading_progress/{progressId} {
      allow get: if isAuthenticated() && (isAdmin() || progressId.startsWith(request.auth.uid) || resource.data.userId == request.auth.uid);
      allow list: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && (isAdmin() || (request.resource.data.userId == request.auth.uid && isValidProgress(request.resource.data)));
      allow update: if isAuthenticated() && (isAdmin() || (resource.data.userId == request.auth.uid && isValidProgress(request.resource.data)));
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /favorites/{favoriteId} {
      allow get: if isAuthenticated() && (isAdmin() || favoriteId.startsWith(request.auth.uid) || resource.data.userId == request.auth.uid);
      allow list: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && (isAdmin() || (request.resource.data.userId == request.auth.uid && isValidFavorite(request.resource.data)));
      allow update: if isAuthenticated() && (isAdmin() || (resource.data.userId == request.auth.uid && isValidFavorite(request.resource.data)));
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidRating(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidRating(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
